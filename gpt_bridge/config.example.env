# Required for OpenAI API calls
OPENAI_API_KEY=your_openai_api_key_here

# Bridge listener
GPT_BRIDGE_HOST=127.0.0.1
GPT_BRIDGE_PORT=8787
# Set to 1 only when intentionally binding non-localhost (for remote hosting)
# GPT_BRIDGE_ALLOW_NONLOCALHOST=1

# Default model when no per-request override is provided
# Task routing currently uses:
# - general/report -> gpt-5.2
# - qa_check/score_check -> gpt-5-mini
GPT_BRIDGE_MODEL=gpt-5.2

# Authentication to /ask (set at least one)
GPT_BRIDGE_TOKEN=replace_with_long_random_token
# GPT_BRIDGE_SHARED_SECRET=replace_with_long_random_secret

# Optional overrides
GPT_BRIDGE_URL=http://127.0.0.1:8787/ask
# Optional client-side host allowlist (comma-separated)
# Example: GPT_BRIDGE_ALLOWED_HOSTS=127.0.0.1,localhost,gpt-bridge.bitpod.app
# GPT_BRIDGE_ALLOWED_HOSTS=127.0.0.1,localhost

# Server-side hardening controls
# GPT_BRIDGE_MAX_REQUEST_BYTES=131072
# GPT_BRIDGE_MAX_TOKENS_CAP=2000
# GPT_BRIDGE_RATE_LIMIT_PER_MINUTE=120
# GPT_BRIDGE_LOG_REDACT=1
# GPT_BRIDGE_LOG_MAX_CHARS=400
GPT_BRIDGE_LOG_FILE=logs/bridge.jsonl
