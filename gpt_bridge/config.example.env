# Required for OpenAI API calls
OPENAI_API_KEY=your_openai_api_key_here

# Bridge listener (must remain localhost)
GPT_BRIDGE_HOST=127.0.0.1
GPT_BRIDGE_PORT=8787

# Default model when no per-request override is provided
# Task routing currently uses:
# - general/report -> gpt-5.2
# - qa_check/score_check -> gpt-5-mini
GPT_BRIDGE_MODEL=gpt-5.2

# Authentication to /ask (set at least one)
GPT_BRIDGE_TOKEN=replace_with_long_random_token
# GPT_BRIDGE_SHARED_SECRET=replace_with_long_random_secret

# Optional overrides
GPT_BRIDGE_URL=http://127.0.0.1:8787/ask
GPT_BRIDGE_LOG_FILE=logs/bridge.jsonl
