# v1 bootstrap defaults
DRY_RUN=true
BOT_HOST=127.0.0.1
BOT_PORT=8787

# future/live wiring
# VERA_QA_GATE_GITHUB_APP_ID=
# VERA_QA_GATE_GITHUB_APP_INSTALLATION_ID=
# VERA_QA_GATE_GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# Preferred for agent/app actors: Linear OAuth app client credentials;
# the executor mints short-lived access tokens with client_credentials.
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# LINEAR_OAUTH_SCOPE=read write
# Emergency fallback only: a short-lived OAuth bearer token.
# LINEAR_OAUTH_ACCESS_TOKEN=
# Legacy fallback for local personal scripts only; do not prefer this for agent actors.
# LINEAR_API_KEY=
# LINEAR_WEBHOOK_SECRET=

# Vera auto-QA dispatcher (default off; never commit real secret values)
VERA_QA_DISPATCH_ENABLED=false
# Review workspace used for reading the PR checkout.
# VERA_QA_KANBAN_WORKSPACE=scratch
# Runtime artifact root used for Vera-generated manifest/report files; must be outside reviewed repos.
# VERA_QA_ARTIFACT_ROOT=~/.hermes/profiles/vera/qa-artifacts
VERA_QA_GATE_LIVE_ENABLED=false
# Either inject a short-lived installation token, or inject app credentials from a secret store.
# VERA_QA_GATE_GITHUB_TOKEN=
# VERA_QA_GATE_GITHUB_APP_ID=
# VERA_QA_GATE_GITHUB_APP_INSTALLATION_ID=
# VERA_QA_GATE_GITHUB_APP_PRIVATE_KEY=

# guarded Linear live executor (default off; never commit real values)
LINEAR_LIVE_EXECUTOR_ENABLED=false
# Exact Class-B rollout allowlist; comma-separated system:kind:target entries, no wildcards.
# LINEAR_GUARDED_ACTION_ALLOWLIST=linear:set_status:BIT-505
# LINEAR_API_URL=https://api.linear.app/graphql
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# LINEAR_OAUTH_SCOPE=read write
# LINEAR_OAUTH_ACCESS_TOKEN=
# LINEAR_EXPECTED_ACTOR_ID=
# LINEAR_EXPECTED_ACTOR_NAME=
# LINEAR_EXPECTED_ACTOR_EMAIL=

# provider + portability
LLM_PROVIDER=openai
LLM_MODEL=gpt-5
MEMORY_BACKEND=memory
